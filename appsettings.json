{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=LibraryDB;User=root;Password=;"
  }
}
/*
Server=localhost   → сервер MySQL находится на нашем компьютере
Port=3306          → стандартный порт MySQL
Database=LibraryDB → название базы данных (создастся автоматически)
User=root          → стандартный пользователь XAMPP
Password=          → в XAMPP по умолчанию пароль пустой
*/
